{/block}

{block scripts}
    <script>
        /**
         * @namespace { Grid } newsGrid
         */
        var newsGrid;

        $(function () {
            newsGrid = {$newsGrid|noescape};
            newsGrid.onSelect = function (e) {
                let data = newsGrid.getCurrentItem();
                if (data.File_ID) {
                    $('#image-preview').attr('src', '/common/file/download?ID=' + data.File_ID);
                } else {
                    $('#image-preview').attr('src', '');
                }
            };

            tree = new TreeView('category-tree', {$tree}, true);
            tree.onChange = function () {
                let selected = tree.getSelected();

                newsGrid.setUrlParameter('Category_IDs', selected);
                newsGrid.refresh();
            }
        });

        var previewNews = function () {
            window.open(basePath + '/{URL::NEWS|noescape}/' + newsGrid.getCurrentItem().slug);
        }


        $(function () {
            if ($(window).width() < 769) {
                toggleFilter($('#blogList-filter .header'), 0);
            }
            $('#blogList-filter .header').on('click', (e) => {
                var target = $(e.target).is('.header') ? $(e.target) : $(e.target).closest('.header');
                toggleFilter(target);
            });
        });

        var toggleFilter = function (target, time = 300) {
            target.toggleClass('open');
            if (target.hasClass('open')) {
                target.parents('.blog-filter').toggleClass('open', false);
                target.parents('.blog-filter').next('.blogList-dataGrid').toggleClass('open', false);
                setTimeout(() => {
                    target.parent().find('.content').slideDown(time);
                }, ($(window).width() > 768) ? 300 : 0);
            } else {
                target.parents('.blog-filter').toggleClass('open', true);
                target.parents('.blog-filter').next('.blogList-dataGrid').toggleClass('open', true);
                if ($(window).width() > 768) {
                    target.parent().find('.content').hide(0);
                } else {
                    target.parent().find('.content').slideUp(time);
                }
            }
        }
    </script>
{/block}