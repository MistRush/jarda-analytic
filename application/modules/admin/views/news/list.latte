{layout "../layout.latte"}
{block content}
    <div class="row blogList">
        <div class="blog-filter">
            <div id="blogList-filter" class="mb-4 mb-md-0">
                <div class="header open">
                    <span>Filtr dle kategorie</span>
                    <i class="ci ci-angle-down"></i>
                </div>
                <div class="content">
                    <div id="category-tree" style="max-height: 320px; overflow:auto;"></div>
                </div>
            </div>
        </div>
        <div class="blogList-dataGrid">
             <div class="row">
                    <div class="col-md-10">
                        {$newsGrid->render()}
                    </div>
                    <div class="col-md-2">
                        <div><img src="" id="image-preview"></div>
                    </div>
                </div>
        </div>
    </div>



