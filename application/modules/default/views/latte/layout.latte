                <div class="form">
                    <script src="https://www.google.com/recaptcha/api.js?render=6LdSvYUsAAAAAMEc4A38re5VImJbJI1Jz04BF2PX"></script>
                    <form class="contact-form contact-form-page" id="contact-us-form" method="post" action="#">
                        <h3>Write to Us</h3>
                        <p>Have a question or need our expertise? Send us a message.</p>
                        <div class="row">
                            <div class="col-lg-6 wrapper">
                                <fieldset class="formRow">
                                    <div class="formRow--item">
                                        <label for="name" class="formRow--input-wrapper js-inputWrapper">Full Name</label>
                                            <input class="formRow--input js-input" id="name" type="text" name="name"
                                                   data-validator='[{ "v":":required","m":"{_('Fill your Name')}","p":null}]'
                                                   placeholder="Full Name*">
                                    </div>
                                </fieldset>
                            </div>
                            <div class="col-lg-6 wrapper">
                                <fieldset class="formRow">
                                    <div class="formRow--item">
                                        <label for="company" class="formRow--input-wrapper js-inputWrapper">Company</label>
                                        <input class="formRow--input js-input" id="company" type="text" name="company"
                                               data-validator='[{ "v":":required","m":"{_('Fill Company')}","p":null}]'
                                               placeholder="Company*">
                                    </div>
                                </fieldset>
                            </div>
                            <div class="col-lg-6 wrapper">
                                <fieldset class="formRow">
                                    <div class="formRow--item">
                                        <label for="email" class="formRow--input-wrapper js-inputWrapper">E-mail Address</label>
                                            <input class="formRow--input js-input" id="email" type="text"
                                                   name="email"
                                                   data-validator='[{ "v":":email","m":"{_('Fill email')}","p":null}]'
                                                   placeholder="Email*">
                                    </div>
                                </fieldset>
                            </div>
                            <div class="col-lg-6 wrapper">
                                <fieldset class="formRow">
                                    <div class="formRow--item">
                                        <label for="subject" class="formRow--input-wrapper subject js-inputWrapper active">Subject</label>

                                        <div class="custom-select-container">
                                            <select class="formRow--input formRow-select d-none" id="subject" name="subject">
                                                <option value="Technical Audits" selected>Technical Audits</option>
                                                <option value="Aircraft Inspections">Aircraft Inspections</option>
                                                <option value="Engineering Support">Engineering Support</option>
                                                <option value="Asset Management">Asset Management</option>
                                                <option value="Compliance Consulting">Compliance Consulting</option>
                                            </select>

                                            <div class="custom-select-trigger">
                                                <span>Technical Audits</span>
                                                <i class="arrow-icon"></i> </div>
                                            <div class="custom-options">
                                                <div class="custom-option selected" data-value="Technical Audits">Technical Audits</div>
                                                <div class="custom-option" data-value="Aircraft Inspections">Aircraft Inspections</div>
                                                <div class="custom-option" data-value="Engineering Support">Engineering Support</div>
                                                <div class="custom-option" data-value="Asset Management">Asset Management</div>
                                                <div class="custom-option" data-value="Compliance Consulting">Compliance Consulting</div>
                                            </div>
                                        </div>
                                    </div>
                                </fieldset>
                            </div>
                            <div class="col-lg-12 wrapper">
                                <fieldset class="formRow formRow-textarea">
                                    <div class="formRow--item">
                                        <label for="message" class="formRow--input-wrapper active">Message</label>
                                        <textarea class="formRow--input js-input" id="message" name="message"
                                                  placeholder="Zpráva" rows="4"></textarea>
                                    </div>
                                </fieldset>
                            </div>
                        </div>
                        <div class="flex-wrapper row mt-3 contact-form-info">
                            <div class="col-lg-6 flex-item"></div>
                            <div class="col-lg-6 flex-item button-holder">
                                <a class="btn-pink g-recaptcha" id="confirm-contact-form">Send Message</a></div>
                        </div>
                    </form>
                </div>
            </div>
            <div class="footer-info">
                <div class="basic">
                    <div class="logo"><img alt="logo" src="/img/front/header-logo.svg"></div>
                    <div class="text">
                        Aviation experts providing specialized advice on<br>
                        aircraft maintenance, compliance, and asset<br> management.
                    </div>
                    <a href="/" class="linkedin-holder gradient-border">
                        <img src="/img/front/linkedin.svg" alt="linkedin">
                    </a>
                </div>
                <div class="links">
                    <div class="navigation">
                        <div class="name">Navigation</div>
                        <div class="navigation-items">
                            <div class="holder">
                                <a href="#about-us">About us</a>
                                <a href="#services">Our services</a>
                                <a href="#work">Gallery</a>
                            </div>
                            <div class="holder">
                                <a href="#clients">Clients</a>
                                <a href="#footer">Contacts</a>
                            </div>
                        </div>
                    </div>
                    <div class="navigation">
                        <div class="name">Navigation</div>
                        <div class="navigation-items">
                            <div class="holder">
                                <a href="#services">Technical Audits</a>
                                <a href="#services">Aircraft Inspections</a>
                                <a href="#services">Engineering Support</a>
                            </div>
                            <div class="holder">
                                <a href="#services">Asset Management</a>
                                <a href="#services">Compliance Consulting</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="credits">
                <div class="rights">
                    © 2025 TRYMyengineering s.r.o., všechna práva vyhrazena.
                </div>
                <div class="evidsoft">
                    <span>Powered by:</span>
                    <a href="https://www.evidsoft.cz" target="_blank" rel="nofollow noopener noreferrer">
                        <img src="/img/front/evidsoft-logo.png" alt="Evidsoft s.r.o.">
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

{$cookiesConfirm|noescape}
<script>
    $(document).ready(function() {
        $('.custom-select-trigger').click(function(e) {
            $(this).parent().toggleClass('open');
            e.stopPropagation();
        });

        $('.custom-option').click(function() {
            const value = $(this).data('value');
            const text = $(this).text();
            const container = $(this).closest('.custom-select-container');

            container.find('.custom-select-trigger span').text(text);
            container.find('.custom-option').removeClass('selected');
            $(this).addClass('selected');

            const realSelect = container.find('select');
            realSelect.val(value).trigger('change');

            container.removeClass('open');
        });

        $(window).click(function() {
            $('.custom-select-container').removeClass('open');
        });
    });
</script>
<script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
<script>
    AOS.init();
</script>
<script>
    var header = $("#header");
    var scrollChange = 1;
    $(window).scroll(function() {
        var scroll = $(window).scrollTop();

        if (scroll >= scrollChange) {
            header.addClass('bg-purple');
        } else {
            header.removeClass("bg-purple");
        }
    });
</script>
<script>
    window.projectVars = {
        basePath: {$bp},
        currencyLabel: {$currency['Label']},
        priceDecimalPlaces: {$eshop->getEshop()->settings->PriceDecimalPlaces},
        confirm: {_('Potvrdit')},
        cancel: {_('Zrušit')},
        currentURI: {$uri},
        url: {
            product: {URL::PRODUCT},
            page: {URL::PAGE},
            category: {URL::CATEGORY},
        },
    }
</script>

<script src="{$bp}/js/assets/popper/popper.min.js" defer></script>
<script src="{$bp}/js/assets/bootstrap/js/bootstrap.min.js" defer></script>

