                        </div>
                        <div class="info-item">
                            <div class="icon-holder gradient-border">
                                <img src="/img/front/suitcase.svg" alt="phone">
                            </div>
                            <div class="info-text">
                                <span>COMPANY ID (IČO)</span><br>
                                22270019
                            </div>
                        </div>
                        <div class="info-item">
                            <div class="icon-holder gradient-border">
                                <img src="/img/front/email.svg" alt="phone">
                            </div>
                            <div class="info-text">
                                <span>EMAIL</span><br>
                                <a href="mailto:info@trym.cz">info@trym.cz</a>
                            </div>
                        </div>
                    </div>
