{
  "include": [
    "src/**/*",
    "src/**/*.vue",
    "../www/jolanda/front-vue/**/*",
    "../www/jolanda/front-vue/**/*.vue",
    "vite.config.*",
    "vitest.config.*",
    "cypress.config.*",
    "nightwatch.conf.*",
    "playwright.config.*",
  ],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@project/*": ["./src/*"],
      "@/*": ["../www/jolanda/front-vue/src/*"],
      "@front/*": ["../www/project/*"],
    },
    "experimentalDecorators": true
  }
}
