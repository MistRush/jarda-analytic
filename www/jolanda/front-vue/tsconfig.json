{
//    "extends": "@vue/tsconfig/tsconfig.dom.json",
    "include": [
//        "env.d.ts",
        "src/**/*",
        "src/**/*.vue",
    ],
    "exclude": ["src/**/__tests__/*"],
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "types": ["node"],
        "composite": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
        },
        "experimentalDecorators": true
    }
}